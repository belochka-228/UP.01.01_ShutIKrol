<Page x:Class="UP._01._01_ShutIKrol.Pages.ReadingListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReadingListsPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="TxtSearch" Width="180" Height="26" Margin="5,0" TextChanged="TxtSearch_TextChanged"/>
            <TextBlock Text="Сорт." VerticalAlignment="Center" Margin="10,0,5,0" FontSize="14"/>
            <ComboBox x:Name="CmbSort" Width="150" Height="26" SelectedIndex="0" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem>Без</ComboBoxItem>
                <ComboBoxItem>По названию</ComboBoxItem>
                <ComboBoxItem>По рейтингу</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="ListBoxStatuses" BorderThickness="0" Background="Transparent" SelectionChanged="ListBoxStatuses_SelectionChanged">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="10" Margin="3" Padding="5">
                        <Button Content="{Binding Name}" BorderThickness="0" Background="Transparent" IsHitTestVisible="False" Focusable="False"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <ListBox Grid.Row="2" x:Name="ListBoxBooks" MouseDoubleClick="ListBoxBooks_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Books.Title}" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding Books.Users.DisplayName, StringFormat='Автор: {0}'}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Переместить" Width="110" Height="28" Background="#FFDDDDDD" BorderThickness="1" BorderBrush="#AAAAAA" FontSize="12" Click="BtnMove_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
