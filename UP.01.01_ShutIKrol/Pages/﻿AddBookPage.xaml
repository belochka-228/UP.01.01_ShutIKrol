<Page x:Class="UP._01._01_ShutIKrol.Pages.__AddBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="__AddBookPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Добавление книги" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Левая колонка: обложка, название, жанры, описание -->
        <StackPanel Grid.Row="1" Grid.Column="0" Width="300" Margin="0,0,10,0">
            <TextBlock Text="Обложка (путь):"/>
            <TextBox x:Name="TxtCoverPath" Margin="0,5,0,10"/>

            <TextBlock Text="Название:"/>
            <TextBox x:Name="TxtTitle" Margin="0,5,0,10"/>

            <TextBlock Text="Жанры:"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <ComboBox x:Name="CmbGenre" Width="150" Height="26" DisplayMemberPath="Name"/>
                <Button Content="Добавить" Width="80" Height="26" Margin="5,0,0,0"
                        Background="#FFDDDDDD" BorderThickness="1" BorderBrush="#AAAAAA"
                        Click="BtnAddGenre_Click"/>
            </StackPanel>
            <ListBox x:Name="ListBoxGenres" Height="80">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="Описание:" Margin="0,10,0,0"/>
            <TextBox x:Name="TxtDescription" Height="80" TextWrapping="Wrap" Margin="0,5,0,10"/>
        </StackPanel>

        <!-- Правая колонка: текст книги -->
        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="Текст книги:"/>
            <TextBox x:Name="TxtContent" Height="300" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- Кнопка Добавить -->
        <Button Grid.Row="2" Grid.ColumnSpan="2" Content="Добавить книгу"
                Width="200" Height="35" Margin="0,10,0,0"
                Background="#4CAF50" Foreground="White" BorderThickness="0"
                Click="BtnAdd_Click"/>
    </Grid>
</Page>
