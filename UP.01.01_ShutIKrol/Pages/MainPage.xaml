<Page x:Class="UP._01._01_ShutIKrol.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFF0F0F0">
            <StackPanel VerticalAlignment="Top" Margin="0,10,0,0">

                <Button ToolTip="Каталог книг" Width="50" Height="30" Click="BtnCatalog_Click" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/catalog.png"></Image>
                </Button>

                <Button ToolTip="Мои списки" Width="50" Height="30" Click="BtnLists_Click">
                    <Image Source="/Images/spiski.png"></Image>
                </Button>

                <Button ToolTip="Каталог книг" Width="50" Height="30" Click="OnClick5">
                    <Image Source="/Images/catalog.png"></Image>
                </Button>


                <Button ToolTip="Мои списки" Click="BtnLists_Click" Style="{StaticResource SidebarButton}">
                    📋
                </Button>

                <Button x:Name="BtnAdmin" ToolTip="Администрирование" Click="BtnAdmin_Click" Style="{StaticResource SidebarButton}"
                        Visibility="Collapsed">
                    ⚙️
                </Button>

                <Button x:Name="BtnAuthor" ToolTip="Страница автора" Click="BtnAuthor_Click" Style="{StaticResource SidebarButton}"
                        Visibility="Collapsed">
                    ✍️
                </Button>

                <Button x:Name="BtnFrozen" ToolTip="Аккаунт заморожен" Click="BtnFrozen_Click" Style="{StaticResource SidebarButton}"
                        Visibility="Collapsed">
                    ⚠️
                </Button>

                <Button ToolTip="Профиль" Click="BtnProfile_Click" Style="{StaticResource SidebarButton}">
                    👤
                </Button>

            </StackPanel>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>