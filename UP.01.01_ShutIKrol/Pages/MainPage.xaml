<Page x:Class="UP._01._01_ShutIKrol.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFF0F0F0">
            <StackPanel VerticalAlignment="Top" Margin="0,10,0,0">

                <Button ToolTip="Каталог книг" Width="60" Height="40" Click="BtnCatalog_Click" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/catalog.png"></Image>
                </Button>

                <Button ToolTip="Мои списки" Width="60" Height="40" Click="BtnLists_Click" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/spiski.png"></Image>
                </Button>

                <Button x:Name="BtnAdmin" ToolTip="Администрирование" Width="60" Height="40" Click="BtnAdmin_Click" Visibility="Collapsed" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/param.png"></Image>
                </Button>

                <Button x:Name="BtnAuthor" ToolTip="Страница автора" Width="60" Height="40" Click="BtnAuthor_Click" Visibility="Collapsed" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/author.png"></Image>
                </Button>

                <Button x:Name="BtnFrozen" ToolTip="Аккаунт заморожен" Width="60" Height="40" Click="BtnFrozen_Click" Visibility="Collapsed" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/signal.png"></Image>
                </Button>

                <Button ToolTip="Профиль" Width="60" Height="40" Click="BtnProfile_Click" Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/profil.png"></Image>
                </Button>
            </StackPanel>
        </Border>

        <Button ToolTip="Выход из профиля" Width="60" Height="40" VerticalAlignment="Bottom" Click="BtnBack_Click" Style="{StaticResource ImageButtonStyle}">
            <Image Source="/Images/back.png"></Image>
        </Button>

        <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>