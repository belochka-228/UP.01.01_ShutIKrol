<Page x:Class="UP._01._01_ShutIKrol.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Вход"
      Background="White">
    
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Width="300">
            <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин"/>
            <TextBox x:Name="txtUser" Margin="0,5,0,10" Height="25"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="txtPassword" Margin="0,5,0,20" Height="25"/>

            <Button Content="Войти" Height="30" Click="AutoButton_Click" 
                    Background="#4CAF50" Foreground="White" BorderThickness="0"/>
            <Button Content="Регистрация" Height="30" Click="RegisterButton_Click" 
                    Background="Transparent" BorderThickness="1" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Page>