<Window x:Class="UP._01._01_ShutIKrol.Pages.ComplaintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="ComplaintWindow" Height="450" Width="800">

    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Подача жалобы" FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtTargetInfo" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtTargetName" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <TextBlock Text="Причина жалобы:" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbReasons" DisplayMemberPath="Name"/>

            <Button x:Name="BtnSend" Content="✉ Отправить жалобу" Width="180" Height="35" 
                    Margin="0,20,0,0"
                    Background="#FF5722" Foreground="White" BorderThickness="0"
                    FontWeight="Bold" Cursor="Hand"
                    Click="BtnSend_Click"/>
        </StackPanel>
    </Grid>
</Window>