<Window x:Class="UP._01._01_ShutIKrol.Pages.WindowReadText"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
        mc:Ignorable="d"
        Title="WindowReadText" 
        Height="450" 
        Width="800">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Button x:Name="BtnBack" Content="Назад" HorizontalAlignment="Left" VerticalAlignment="Center" Width="80" Height="30" Click="ButtonBack_Click"/>
            <TextBlock Text="Чтение текста" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F9F9F9">
            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="16" Padding="20" LineHeight="24" Foreground="#333333"/>
        </ScrollViewer>
    </Grid>
</Window>