<Window x:Class="UP._01._01_ShutIKrol.Pages.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
        mc:Ignorable="d"
        Title="ChangePasswordWindow" Height="400" Width="400">

    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Новый пароль" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBoxNew" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Повторите пароль" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBoxRepeat" Height="30" Margin="0,0,0,20"/>

            <Button Content="Сохранить" Height="30" Width="80" Background="Green" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
