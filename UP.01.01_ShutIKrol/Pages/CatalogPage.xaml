<Page x:Class="UP._01._01_ShutIKrol.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFF5F5F5" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtSearch" Width="250" Height="28" Margin="5,0"
                             TextChanged="TxtSearch_TextChanged"
                             ToolTip="Поиск по названию или автору"/>
                </DockPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="CmbSort" Width="160" Height="28"
                              SelectedIndex="0" SelectionChanged="CmbSort_SelectionChanged">
                        <ComboBoxItem>Без сортировки</ComboBoxItem>
                        <ComboBoxItem>По названию (А-Я)</ComboBoxItem>
                        <ComboBoxItem>По рейтингу (убыв.)</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <ComboBox x:Name="CmbGenres" Width="160" Height="28"
                              SelectionChanged="CmbGenres_SelectionChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="1" x:Name="ListBoxBooks"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="ListBoxBooks_MouseDoubleClick">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="160" Margin="8" Background="White"
                            CornerRadius="10" Padding="8"
                            Cursor="Hand" ToolTip="Двойной клик — открыть книгу">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Color="#20000000" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <Image Source="{Binding CoverPath}"
                                   Width="140" Height="180"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13"
                                       TextTrimming="CharacterEllipsis" Margin="0,6,0,2"/>
                            <TextBlock Text="{Binding Users.DisplayName, StringFormat='Автор: {0}'}"
                                       FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
