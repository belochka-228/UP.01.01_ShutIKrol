<Page x:Class="UP._01._01_ShutIKrol.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="TxtSearch" Width="180" Height="26"
                     TextChanged="TxtSearch_TextChanged"/>
            <TextBlock Text="Сорт." VerticalAlignment="Center" Margin="10,0,5,0" FontSize="14"/>
            <!-- Заменили ComboBox на ContentControl для программного создания -->
            <ContentControl x:Name="SortPlaceholder" Width="150" Height="26"
                            VerticalAlignment="Center" Margin="0,0,0,0"/>
            <TextBlock Text="Жанр" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="14"/>
            <ContentControl x:Name="GenrePlaceholder" Width="150" Height="26"
                            VerticalAlignment="Center" Margin="0,0,0,0"/>
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="ListBoxBooks"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="ListBoxBooks_MouseDoubleClick">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="170" Margin="8" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
                            Padding="8" Cursor="Hand">
                        <StackPanel>
                            <Image Source="{Binding CoverPath}" Width="150" Height="190"
                                   Stretch="UniformToFill"/>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13"
                                       Margin="0,6,0,2"/>
                            <TextBlock Text="{Binding Users.DisplayName, StringFormat='Автор: {0}'}"
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                            <Button Content="Добавить в список" Width="130" Height="28"
                                    Background="#FFDDDDDD" BorderThickness="1"
                                    BorderBrush="#AAAAAA" FontSize="12"
                                    Click="BtnAddToList_Click"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>