<Page x:Class="UP._01._01_ShutIKrol.Pages.BookDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" 
      d:DesignWidth="800"
      Title="BookDetailPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <Button x:Name="Btn_Back" Content="Назад" HorizontalAlignment="Left"  Background="SeaShell" BorderThickness="0" FontSize="16" Margin="0,0,0,10" Click="BtnBack_Click"/>

            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <Image Source="{Binding CoverPath}" Width="300" Height="350" Stretch="UniformToFill" Margin="0,0,15,0"/>
                    <StackPanel Margin="0,10,15,0">
                        <Button Content="Читать" Height="35" Background="#4CAF50" Foreground="White" Click="BtnRead_Click" Margin="0,0,0,5"/>
                        <Button Content="Добавить в список" Height="35" Background="#2196F3" Foreground="White" Click="BtnAddToList_Click" Margin="0,0,0,5"/>
                        <Button x:Name="BtnFreezeBook" Content="Заморозить книгу" Height="35" Background="#BDBDBD" Foreground="Black"  Click="BtnFreezeBook_Click" Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Button Content="Пожаловаться на книгу" Background="Transparent" Foreground="Red" Cursor="Hand" Click="BtnComplaintBook_Click"  Margin="0,0,10,0"/>
                        <Button Content="Пожаловаться на автора" Background="Transparent" Foreground="Red" Cursor="Hand" Click="BtnComplaintAuthor_Click"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Автор:" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding Users.DisplayName}" FontSize="16" Foreground="Black" Margin="5,0,0,5"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="★" FontSize="20" Foreground="#FFD700"/>
                        <TextBlock x:Name="TxtRating" FontSize="18" Margin="5,0,0,5"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Жанры:" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                        <ItemsControl ItemsSource="{Binding BookGenres}" >
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Genres.Name}" FontSize="14" Margin="5,0,0,5" Foreground="Black"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    
                    <TextBlock Text="Описание книги:" FontWeight="Bold" FontSize="16" Margin="0,10,0,5"/>
                    <TextBlock Text="{Binding Description}" Width="500" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,5"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Оставить отзыв" FontSize="20" FontWeight="Bold" Margin="0,15,0,15"/>
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5"  Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBox x:Name="TxtNewReview" Height="60" TextWrapping="Wrap"  Margin="0,0,0,5" ToolTip="Введите текст отзыва"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Оценка:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="CmbRating" Width="80" Height="26" SelectedIndex="7">
                            <ComboBoxItem>1</ComboBoxItem>
                            <ComboBoxItem>2</ComboBoxItem>
                            <ComboBoxItem>3</ComboBoxItem>
                            <ComboBoxItem>4</ComboBoxItem>
                            <ComboBoxItem>5</ComboBoxItem>
                            <ComboBoxItem>6</ComboBoxItem>
                            <ComboBoxItem>7</ComboBoxItem>
                            <ComboBoxItem>8</ComboBoxItem>
                            <ComboBoxItem>9</ComboBoxItem>
                            <ComboBoxItem>10</ComboBoxItem>
                        </ComboBox>
                        <Button Content="Отправить" Width="100" Height="26" Margin="10,0,0,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="BtnSubmitReview_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Отзывы" FontSize="20" FontWeight="Bold" Margin="0,15,0,15"/>
            <ItemsControl x:Name="ReviewsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5"  Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Users.DisplayName}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" FontSize="12" Foreground="Gray"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Rating, StringFormat='★{0}'}" FontWeight="Bold" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,5,15,10"/>
                                    <Button Content="Жалоба" Background="Transparent" Foreground="#2196F3" Margin="0,5,15,10" Click="BtnComplaintReview_Click" Tag="{Binding Id}"  VerticalAlignment="Center"/>
                                    <Button x:Name="BtnFreezeReview" Content="Заморозить" Background="Transparent" Foreground="#FF5722" Margin="0,5,15,10" Click="BtnFreezeReview_Click" Tag="{Binding Id}" Visibility="Collapsed" Loaded="BtnFreezeReview_Loaded" />
                                </StackPanel>
                                <TextBlock Text="{Binding Text}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>