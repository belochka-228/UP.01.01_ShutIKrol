<Page x:Class="UP._01._01_ShutIKrol.Pages.Register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Register">

    <Grid>
        <TextBlock Text="Страница регистрации" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" FontSize="18"/>

        <TextBlock Text="Логин:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,80,0,0"/>
        <TextBox x:Name="txtUser" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150,80,0,0" Width="200"/>
        
        <TextBlock Text="Email(почта):" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,120,0,0"/>
        <TextBox x:Name="txtEmail" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150,120,0,0" Width="200"/>

        <TextBlock Text="Пароль:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,160,0,0"/>
        <PasswordBox x:Name="txtPassword" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="150,160,0,0" Width="200"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,200,0,0">
            <Button Content="Назад" Width="100" Height="30" Margin="5" Click="AutoButton_Click"/>
            <Button Content="Зарегистрироваться" Width="120" Height="30" Margin="5" Click="RegisterButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
