<Page x:Class="UP._01._01_ShutIKrol.Pages.Register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP._01._01_ShutIKrol.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" 
      d:DesignWidth="800"
      Title="Регистрация"
      Background="#FFF8F8F8">
    
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        
        <StackPanel Width="300">
            <TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин" Margin="0,0,0,3"/>
            <TextBox x:Name="txtLogin" Height="28" Margin="0,0,0,10"/>

            <TextBlock Text="Отображаемое имя" Margin="0,0,0,3"/>
            <TextBox x:Name="txtDisplayName" Height="28" Margin="0,0,0,10"/>

            <TextBlock Text="Email" Margin="0,0,0,3"/>
            <TextBox x:Name="txtEmail" Height="28" Margin="0,0,0,10"/>

            <TextBlock Text="Пароль" Margin="0,0,0,3"/>
            <PasswordBox x:Name="txtPassword" Height="28" Margin="0,0,0,10"/>

            <TextBlock Text="Повторите пароль" Margin="0,0,0,3"/>
            <PasswordBox x:Name="txtPasswordConfirm" Height="28" Margin="0,0,0,20"/>

            <Button Content="Зарегистрироваться" Height="30" Click="Register_Click" Background="#4CAF50" Foreground="White" />
            <Button Content="Назад" Height="30" Click="Back_Click" Background="Transparent" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Page>